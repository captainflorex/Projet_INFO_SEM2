#---------------------------------------------------------------------------
# Project related configuration options
#---------------------------------------------------------------------------

PROJECT_NAME           = "MonProjet"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "Documentation générée automatiquement"

OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

ALLOW_UNICODE_NAMES    = YES

#---------------------------------------------------------------------------
# Build related configuration options
#---------------------------------------------------------------------------

DOXYFILE_ENCODING      = UTF-8
FULL_PATH_NAMES        = YES

#---------------------------------------------------------------------------
# Warning options
#---------------------------------------------------------------------------

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------

INPUT                  = .
FILE_PATTERNS          = *.h *.hpp *.c *.cpp *.py
RECURSIVE              = YES

EXCLUDE                =
EXCLUDE_PATTERNS       = */build/* */tests/* */cmake-build-debug/*

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

SEARCHENGINE           = YES

#---------------------------------------------------------------------------
# LaTeX / RTF / MAN / XML
#---------------------------------------------------------------------------

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

GENERATE_XML           = YES
XML_OUTPUT             = xml

#---------------------------------------------------------------------------
# Preprocessor
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO

# *** IMPORTANT : corrige le problème Allegro ***
PREDEFINED             += END_OF_MAIN()=

#---------------------------------------------------------------------------
# Dot / Graphviz
#---------------------------------------------------------------------------

HAVE_DOT               = YES
DOT_NUM_THREADS        = 4

CALL_GRAPH             = YES
CALLER_GRAPH           = YES

DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

#---------------------------------------------------------------------------
# MathJax
#---------------------------------------------------------------------------

USE_MATHJAX            = YES
MATHJAX_RELPATH        = https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js

#---------------------------------------------------------------------------
# Doxygen Awesome Theme
#---------------------------------------------------------------------------

HTML_EXTRA_STYLESHEET  = https://cdnjs.cloudflare.com/ajax/libs/doxygen-awesome-css/2.3.1/doxygen-awesome.min.css
HTML_EXTRA_FILES       = https://cdnjs.cloudflare.com/ajax/libs/doxygen-awesome-css/2.3.1/doxygen-awesome-darkmode-toggle.min.js
HTML_EXTRA_FILES      += https://cdnjs.cloudflare.com/ajax/libs/doxygen-awesome-css/2.3.1/doxygen-awesome-sidebar-only.min.css

HTML_COLORSTYLE        = LIGHT

HTML_HEADER            =
HTML_FOOTER            =
HTML_STYLESHEET        =
